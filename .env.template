# Azure Developer CLI environment values
# Copy this to .azure/<env-name>/.env and fill in your values
# Run: azd init -e dev  (creates the .azure/dev/ directory first)

AZURE_LOCATION=westeurope
ACS_CONNECTION_STRING=endpoint=https://<your-acs>.communication.azure.com/;accesskey=<key>
AZURE_VOICE_LIVE_API_KEY=<your-azure-ai-foundry-api-key>
AZURE_VOICE_LIVE_ENDPOINT=https://<your-resource>.services.ai.azure.com
VOICE_LIVE_MODEL=gpt-realtime-mini
TRANSFER_PHONE_NUMBER=+4922180102503
